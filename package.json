{
  "name": "spencerlepine-sdk-js",
  "version": "0.0.1",
  "description": "Printify SDK for JavaScript. Client for Node.js",
  "author": "Spencer Lepine <60903378+spencerlepine@users.noreply.github.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/spencerlepine/spencerlepine-sdk-js/issues"
  },
  "homepage": "https://github.com/spencerlepine/spencerlepine-sdk-js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spencerlepine/spencerlepine-sdk-js.git"
  },
  "keywords": [
    "printify",
    "sdk",
    "javascript",
    "nodejs",
    "api",
    "print-on-demand",
    "printify-sdk",
    "printify-integration",
    "printify-api",
    "node-sdk"
  ],
  "main": "dist/bundle.cjs.js",
  "module": "dist/bundle.esm.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist",
    "docs/API.md"
  ],
  "scripts": {
    "build": "rollup -c",
    "test": "echo \"Done!\" && exit 0",
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "prettier --write",
      "git add"
    ]
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^26.0.1",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/node": "^20.14.10",
    "@typescript-eslint/eslint-plugin": "^5.8.0",
    "@typescript-eslint/parser": "^5.8.0",
    "eslint": "^8.0.0",
    "husky": "4.3.8",
    "lint-staged": "10.5.4",
    "prettier": "2.8.8",
    "rollup": "^2.79.1",
    "rollup-plugin-commonjs": "^10.1.0",
    "rollup-plugin-node-resolve": "^5.2.0",
    "rollup-plugin-terser": "^7.0.2",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">= 18"
  }
}
